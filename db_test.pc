#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sqlca.h>

/* =========================================
   [1] 전역 호스트 변수 선언 (DECLARE SECTION)
   ========================================= */
EXEC SQL BEGIN DECLARE SECTION;
    char *user_id = "system/Password123!@127.0.0.1:1521/xepdb1";
    char acc_no[20];
    VARCHAR user_name[40];
    long current_balance;
    
    /* 비밀번호 및 권한용 */
    char db_pw[15];
    char n_pw[15];
    char db_p[15];
    char db_role[2];

    /* 관리자 조회 커서용 */
    char a_acc_no[20];
    VARCHAR a_user_name[40];
    long a_balance;

    /* 입출금/이체용 */
    long amount;
    char target_acc[20];
    VARCHAR target_name[40];
EXEC SQL END DECLARE SECTION;

/* =========================================
   [2] 공통 유틸리티 및 DB 연결 함수
   ========================================= */
void format_comma(long amt, char *out_str) {
    char temp[50];
    sprintf(temp, "%ld", amt);
    int len = strlen(temp);
    int comma_count = (len - 1) / 3;
    int out_idx = len + comma_count;
    out_str[out_idx] = '\0';
    out_idx--;
    int count = 0;
    for (int i = len - 1; i >= 0; i--) {
        out_str[out_idx--] = temp[i];
        count++;
        if (count % 3 == 0 && i != 0) {
            out_str[out_idx--] = ',';
        }
    }
}

void connect_db() {
    EXEC SQL CONNECT :user_id;
    if (sqlca.sqlcode == 0) {
        printf("2. 오라클 DB 연결 성공!\n");
    } else {
        printf("DB 연결 실패: %.*s\n", sqlca.sqlerrm.sqlerrml, sqlca.sqlerrm.sqlerrmc);
        exit(1);
    }
}

/* =========================================
   [3] 비즈니스 로직 함수 (공통/관리자/고객)
   ========================================= */

/* 로그인 및 라우팅 (2: 관리자, 1: 일반, 0: 실패) */
int login() {
    char input_pw[15];
    
    printf("\n계좌번호 입력: ");
    scanf("%s", acc_no);

    EXEC SQL SELECT USER_NAME, PASSWD, ROLE INTO :user_name, :db_pw, :db_role 
             FROM ACCOUNT WHERE ACC_NO = :acc_no;

    if (sqlca.sqlcode == 1403) {
        printf("[실패] 존재하지 않는 계좌입니다.\n");
        return 0;
    }

    printf("비밀번호 입력: ");
    scanf("%s", input_pw);
    
    for(int i = 14; i >= 0; i--) { 
        if(db_pw[i] == ' ' || db_pw[i] == '\0') db_pw[i] = '\0'; 
        else break; 
    }

    if (strcmp(input_pw, db_pw) != 0) {
        printf("[실패] 비밀번호 불일치\n");
        return 0;
    }

    user_name.arr[user_name.len] = '\0';
    printf("\n[환영합니다] %s님 접속 성공!\n", user_name.arr);
    
    if (db_role[0] == 'A') return 2; 
    return 1; 
}

/* --- [관리자 전용 기능] --- */
void admin_view_accounts() {
    int count = 0;
    char balance_str[50];

    printf("\n==================================================\n");
    printf("           [관리자 모드] 전체 계좌 현황\n");
    printf("==================================================\n");
    printf("%-15s | %-15s | %s\n", "계좌번호", "고객명", "잔액(원)");
    printf("--------------------------------------------------\n");

    EXEC SQL DECLARE acc_cursor CURSOR FOR
        SELECT ACC_NO, USER_NAME, BALANCE FROM ACCOUNT ORDER BY ACC_NO;

    EXEC SQL OPEN acc_cursor;
    EXEC SQL WHENEVER NOT FOUND DO break;

    while (1) {
        EXEC SQL FETCH acc_cursor INTO :a_acc_no, :a_user_name, :a_balance;
        a_user_name.arr[a_user_name.len] = '\0'; 
        format_comma(a_balance, balance_str);

        for(int i = 19; i >= 0; i--) { 
            if(a_acc_no[i] == ' ' || a_acc_no[i] == '\0') a_acc_no[i] = '\0'; 
            else break; 
        }

        printf("%-15s | %-15s | %15s\n", a_acc_no, a_user_name.arr, balance_str);
        count++;
    }

    EXEC SQL CLOSE acc_cursor;

    EXEC SQL WHENEVER NOT FOUND CONTINUE;
    
    printf("--------------------------------------------------\n");
    printf("총 %d개의 계좌가 조회되었습니다.\n", count);
}

/* --- [고객 전용 기능] --- */
void check_balance() {
    char bal_str[50];
    EXEC SQL SELECT BALANCE INTO :current_balance FROM ACCOUNT WHERE ACC_NO = :acc_no;
    format_comma(current_balance, bal_str);
    printf("\n현재 잔액: %s원\n", bal_str);
}

void deposit() {
    printf("\n입금할 금액: ");
    scanf("%ld", &amount);
    EXEC SQL UPDATE ACCOUNT SET BALANCE = BALANCE + :amount WHERE ACC_NO = :acc_no;
    EXEC SQL COMMIT;
    printf("[%ld원] 입금 완료.\n", amount);
}

void withdraw() {
    printf("\n출금할 금액: ");
    scanf("%ld", &amount);
    EXEC SQL SELECT BALANCE INTO :current_balance FROM ACCOUNT WHERE ACC_NO = :acc_no;
    
    if (current_balance < amount) {
        printf("[실패] 잔액이 부족합니다.\n");
        return;
    }
    EXEC SQL UPDATE ACCOUNT SET BALANCE = BALANCE - :amount WHERE ACC_NO = :acc_no;
    EXEC SQL COMMIT;
    printf("[%ld원] 출금 완료.\n", amount);
}

void transfer() {
    printf("\n대상 계좌번호: ");
    scanf("%s", target_acc);
    
    EXEC SQL SELECT USER_NAME INTO :target_name FROM ACCOUNT WHERE ACC_NO = :target_acc;
    if (sqlca.sqlcode == 1403) {
        printf("[실패] 존재하지 않는 계좌입니다.\n");
        return;
    }
    
    printf("이체할 금액: ");
    scanf("%ld", &amount);
    
    EXEC SQL SELECT BALANCE INTO :current_balance FROM ACCOUNT WHERE ACC_NO = :acc_no;
    if (current_balance < amount) {
        printf("[실패] 잔액 부족.\n");
        return;
    }

    EXEC SQL UPDATE ACCOUNT SET BALANCE = BALANCE - :amount WHERE ACC_NO = :acc_no;
    EXEC SQL UPDATE ACCOUNT SET BALANCE = BALANCE + :amount WHERE ACC_NO = :target_acc;
    EXEC SQL COMMIT;
    
    target_name.arr[target_name.len] = '\0';
    printf("[%s]님에게 %ld원 이체 완료.\n", target_name.arr, amount);
}

void change_password() {
    char cur_pw[15], c_pw[15];
    printf("\n현재 PW: ");
    scanf("%s", cur_pw);

    EXEC SQL SELECT PASSWD INTO :db_p FROM ACCOUNT WHERE ACC_NO = :acc_no;
    for(int i = 14; i >= 0; i--) { 
        if(db_p[i] == ' ' || db_p[i] == '\0') db_p[i] = '\0'; 
        else break; 
    }

    if (strcmp(cur_pw, db_p) != 0) {
        printf("[실패] 현재 비밀번호 오류\n");
        return;
    }

    printf("새 PW(4자리): ");
    scanf("%s", n_pw);
    printf("새 PW 확인: ");
    scanf("%s", c_pw);

    if (strcmp(n_pw, c_pw) != 0) {
        printf("[실패] 입력값이 일치하지 않음\n");
        return;
    }

    EXEC SQL UPDATE ACCOUNT SET PASSWD = :n_pw WHERE ACC_NO = :acc_no;
    EXEC SQL COMMIT;
    printf("[성공] 비밀번호가 변경되었습니다.\n");
}

/* =========================================
   [4] 메인 프로그램 (라우팅 제어)
   ========================================= */
int main() {
    int login_status;
    int choice;

    printf("1. 시스템 부팅 중...\n");
    connect_db();

    while(1) {
        printf("\n==================================================\n");
        printf("              C-Stock ATM 시스템\n");
        printf("==================================================\n");
        printf(" 1. 로그인 (Login)\n");
        printf(" 2. 시스템 종료 (Exit)\n");
        printf("선택: ");
        
        scanf("%d", &choice);

        if (choice == 2) {
            printf("[시스템] 안전하게 종료합니다.\n");
            break;
        }
        if (choice != 1) continue;

        login_status = login();

        if (login_status == 2) {
            /* 👑 [세션 분기 A: 관리자] */
            while(1) {
                printf("\n--- [슈퍼 관리자 시스템] ---\n");
                printf("1. 전체 계좌 현황 조회\n");
                printf("2. 로그아웃\n");
                printf("선택: ");
                scanf("%d", &choice);

                if (choice == 1) admin_view_accounts();
                else if (choice == 2) break;
            }
        } 
        else if (login_status == 1) {
            /* 👤 [세션 분기 B: 고객] */
            while(1) {
                printf("\n--- [고객 뱅킹 서비스] ---\n");
                printf("1. 잔액 조회\n");
                printf("2. 입금\n");
                printf("3. 출금\n");
                printf("4. 계좌 이체\n");
                printf("5. 비밀번호 변경\n");
                printf("6. 로그아웃\n");
                printf("선택: ");
                scanf("%d", &choice);

                if (choice == 1) check_balance();
                else if (choice == 2) deposit();
                else if (choice == 3) withdraw();
                else if (choice == 4) transfer();
                else if (choice == 5) change_password();
                else if (choice == 6) break;
            }
        }
    }
    
    EXEC SQL COMMIT WORK RELEASE;
    return 0;
}